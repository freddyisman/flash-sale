{
  "name": "flash-sale",
  "version": "1.0.0",
  "author": "freddy",
  "description": "Flash sale system",
  "main": "main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node-dev ./src/api/main.ts | pino-pretty --colorize",
    "lint": "eslint '{src,test}/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest --config test/vite.config.ts run test",
    "stress-test": "ts-node test/stress-test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.16.2",
    "amqplib": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.29.1",
    "ioredis": "^5.11.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "~2.4.6",
    "@types/eslint": "8.56.10",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.11.0",
    "@types/pino": "7.0.4",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "autocannon": "^8.0.0",
    "eslint": "^8.7.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "lint-staged": "15.2.7",
    "pino-pretty": "11.2.1",
    "prettier": "3.3.3",
    "prisma": "^5.16.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "{src,test}/**/*.{ts,js,json}": [
      "prettier --write '{src,test}/**/*.ts'",
      "eslint --fix",
      "stop-only --file"
    ]
  }
}
